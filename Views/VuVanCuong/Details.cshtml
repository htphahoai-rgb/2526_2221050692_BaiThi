@model _2526_2221050692_BaiThi.Models.LopHoc

@{
    ViewData["Title"] = "Chi tiết Lớp học";
}

<h1>@ViewData["Title"]</h1>
<div>
    <dl class="row">
        <dt class="col-sm-2">Mã lớp</dt>
        <dd class="col-sm-10">@Model.MaLop</dd>

        <dt class="col-sm-2">Tên lớp</dt>
        <dd class="col-sm-10">@Model.TenLop</dd>
    </dl>
</div>
<p>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.MaLop">Sửa</a>
</p>
